[2.120, "o", "\u001b[0;36m[bleeding-edge]\u001b[0m Step 7/7: Skipping systemd service (--no-service)\r\n\r\n\u001b[1m╔══════════════════════════════════════════════════════════╗\u001b[0m\r\n\u001b[1m║  Installation complete                                  ║\u001b[0m\r\n\u001b[1m╚══════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n  Install dir:  /tmp/mlx-cast-install/mlx-engine\r\n  GPU:          gfx1151\r\n  Port:         8099\r\n  Model:        mlx-community/Qwen3-0.6B-4bit\r\n\r\n  Quick start:\r\n    cd /tmp/mlx-cast-install/mlx-engine\r\n    LD_LIBRARY_PATH=. ./chat mlx-community/Qwen3-4B-4bit\r\n\r\n  API server:\r\n    LD_LIBRARY_PATH=. ./server --port 8099\r\n\r\n  Service:\r\n    sudo systemctl start mlx-engine\r\n    curl http://localhost:8099/health\r\n\r\n"]
