{"version":3,"term":{"cols":80,"rows":24},"timestamp":1776242680,"idle_time_limit":3.0,"command":"bash -c '\n    cd /tmp/mlx-cast-install\n    curl -sL https://raw.githubusercontent.com/stampby/bleeding-edge/main/install.sh -o install.sh\n    chmod +x install.sh\n    bash install.sh --install-dir /tmp/mlx-cast-install/mlx-engine --no-service --port 8099 --model mlx-community/Qwen3-0.6B-4bit\n  '","title":"bleeding-edge install — MLX Engine ROCm on Strix Halo","env":{"SHELL":"/usr/bin/zsh"}}
